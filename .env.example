# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=alphaops
POSTGRES_USER=alphaops
POSTGRES_PASSWORD=changeme

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── NewsAPI (optional — falls back to RSS feeds only) ─────────────────────────
NEWS_API_KEY=

# ── Agent schedule intervals (seconds) ───────────────────────────────────────
NEWS_POLL_INTERVAL=300
MARKET_POLL_INTERVAL=60
RISK_POLL_INTERVAL=900

# ── Watchlist (comma-separated tickers) ──────────────────────────────────────
# WATCHLIST=["AAPL","TSLA","NVDA","MSFT","SPY","QQQ","AMZN","META"]

# ── Local LLM (Ollama) ───────────────────────────────────────────────────────
# Set USE_LOCAL_LLM=true to use Ollama instead of Claude API (no API credits needed)
USE_LOCAL_LLM=false
LOCAL_MODEL=qwen3:latest
OLLAMA_URL=http://localhost:11434

# ── Discord ───────────────────────────────────────────────────────────────────
# Get from: Discord channel → Edit Channel → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
