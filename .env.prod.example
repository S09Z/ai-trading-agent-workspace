# ── Environment ───────────────────────────────────────────────────────────────
# Set to production to enable HTTPS via nginx; development serves HTTP only
APP_ENV=production
# OCI Free Tier: Oracle assigns a static public IP — use that until you have a domain
# Let's Encrypt (make ssl-init) requires a real domain, not a bare IP
DOMAIN=your.domain.com

# ── Public-facing URLs (Next.js bakes these in at build time) ─────────────────
# No domain yet (bare IP, HTTP only):
#   NEXT_PUBLIC_API_URL=http://<oci-public-ip>/api
#   NEXT_PUBLIC_WS_URL=ws://<oci-public-ip>/ws
# After SSL with domain:
NEXT_PUBLIC_API_URL=https://your.domain.com/api
NEXT_PUBLIC_WS_URL=wss://your.domain.com/ws

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=alphaops
POSTGRES_USER=alphaops
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── NewsAPI (optional — falls back to RSS feeds) ──────────────────────────────
NEWS_API_KEY=

# ── LLM backend ──────────────────────────────────────────────────────────────
# Priority: Groq → Ollama → Claude (first true wins)
USE_LOCAL_LLM=false      # set true to use Ollama (requires Ollama sidecar)
USE_GROQ=false           # set true to use Groq free cloud API instead of Claude
GROQ_API_KEY=            # get at console.groq.com — free tier, no CC required
GROQ_MODEL=llama-3.3-70b-versatile

# ── Discord ───────────────────────────────────────────────────────────────────
# Bot token from Discord Developer Portal → Bot → Token
DISCORD_BOT_TOKEN=
# Channel ID for digest posts (right-click channel → Copy Channel ID)
DISCORD_DIGEST_CHANNEL_ID=
# Channel ID where bot listens for !commands
DISCORD_BOT_CHANNEL_ID=

# ── Agent schedule intervals (seconds) ───────────────────────────────────────
NEWS_POLL_INTERVAL=300
MARKET_POLL_INTERVAL=60
RISK_POLL_INTERVAL=900

# ── API server ────────────────────────────────────────────────────────────────
DEBUG=false

# ── Notes ─────────────────────────────────────────────────────────────────────
# POSTGRES_HOST, QDRANT_HOST, REDIS_URL are set automatically by docker-compose.prod.yml
# to the internal service names (postgres, qdrant, redis) — do not set them here.
